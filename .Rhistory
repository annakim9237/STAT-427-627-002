head(student, 2)
table(student$G3)
student[sapply(student, is.character)] <- lapply(student[sapply(student, is.character)], as.factor)
head(student,2)
full_log <- glm(pass ~ . - G3, data = train, family = "binomial")
set.seed(321)
train_idx <- sample(1:nrow(student), 0.7*nrow(student))
train <- student[train_idx, ]
test <- student[-train_idx, ]
full_log <- glm(pass ~ . - G3, data = train, family = "binomial")
student$pass <- ifelse(student$G3 >= 10, 1, 0)
student$pass <- as.factor(student$pass)
set.seed(321)
train_idx <- sample(1:nrow(student), 0.7*nrow(student))
train <- student[train_idx, ]
test <- student[-train_idx, ]
full_log <- glm(pass ~ . - G3, data = train, family = "binomial")
summary(full_log)
null_log <- glm(pass ~ 1, data = train, family = "binomial")
step_log <- step(null_log,
scope = list(lower = null_log, upper = full_log),
direction = "both")
summary(step_log)
library(tidyverse)
library(MASS)
student <- read.csv("./student/student-por.csv", header = TRUE, sep = ";")
head(student)
str(student)
dim(student)
student[sapply(student, is.character)] <- lapply(student[sapply(student, is.character)], as.factor)
# Full model
full_model <- lm(G3 ~ . - G1 - G2, data = student)
# Null model
null_model <- lm(G3 ~ 1, data = student)
# AIC stepwise
step_aic <- stepAIC(full_model, direction = "both", trace = FALSE)
summary(step_aic)
# BIC stepwise
step_bic <- stepAIC(full_model, direction = "both", k = log(nrow(student)), trace = FALSE)
summary(step_bic)
# Compare number of predictors selected
length(coef(step_aic)) - 1  # AIC selected predictors
length(coef(step_bic)) - 1  # BIC selected predictors
# Compare AIC and BIC values
AIC(step_aic)
BIC(step_bic)
library(boot)
# AIC model
aic_model <- glm(G3 ~ school + sex + age + Medu + guardian + studytime +
failures + schoolsup + higher + romantic + Dalc + health +
absences, data = student)
# BIC model
bic_model <- glm(G3 ~ school + Fedu + studytime + failures + schoolsup +
higher + Dalc + health, data = student)
# 10-fold CV for both
set.seed(42)
cv_aic <- cv.glm(student, aic_model, K = 10)
cv_bic <- cv.glm(student, bic_model, K = 10)
# CV MSE
cv_aic$delta[1]  # AIC model CV MSE
cv_bic$delta[1]  # BIC model CV MSE
null_log <- glm(pass ~ 1, data = train, family = "binomial")
step_log <- step(null_log,
scope = list(lower = null_log, upper = full_log),
direction = "both")
#,trace = FALSE) - It's too long to show.
summary(step_log)
null_log <- glm(pass ~ 1, data = train, family = "binomial")
step_log <- step(null_log,
scope = list(lower = null_log, upper = full_log),
direction = "both",
trace = FALSE) #- It's too long to show
summary(step_log)
library(boot)
cv_error <- cv.glm(train, step_log, K = 5)
cv_error$delta
cv_error10 <- cv.glm(train, step_log, K = 10)
cv_error10$delta
knitr::opts_chunk$set(echo = TRUE)
student <- read.csv("./student/student-por.csv", header = TRUE, sep = ";")
head(student, 2)
student <- student[, !(names(student) %in% c("G1", "G2"))]
head(student, 2)
table(student$G3)
student[sapply(student, is.character)] <- lapply(student[sapply(student, is.character)], as.factor)
head(student,2)
student$pass <- ifelse(student$G3 >= 10, 1, 0)
student$pass <- as.factor(student$pass)
set.seed(321)
train_idx <- sample(1:nrow(student), 0.7*nrow(student))
train <- student[train_idx, ]
test <- student[-train_idx, ]
# start from full
full_log <- glm(pass ~ . - G3, data = train, family = "binomial")
summary(full_log)
null_log <- glm(pass ~ 1, data = train, family = "binomial")
step_log <- step(null_log,
scope = list(lower = null_log, upper = full_log),
direction = "both",
trace = FALSE) #- It's too long to show
summary(step_log)
library(boot)
cv_error <- cv.glm(train, step_log, K = 5)
cv_error$delta
cv_error10 <- cv.glm(train, step_log, K = 10)
cv_error10$delta
cv_error10 <- cv.glm(train, step_log, K = 10)
cv_error10$delta
mean(log_pred == test$pass)
log_prob <- predict(step_log, test, type = "response")
log_pred <- ifelse(log_prob > 0.5, 1, 0)
log_pred <- as.factor(log_pred)
mean(log_pred == test$pass)
log_prob <- predict(step_log, test, type = "response")
log_pred <- ifelse(log_prob > 0.5, 1, 0)
log_pred <- as.factor(log_pred)
mean(log_pred != test$pass)   # error rate
mean(log_pred == test$pass)   # classification rate
table(test$pass, log_pred)
table(Actual = test$pass, Predicted = log_pred)
knitr::opts_chunk$set(echo = TRUE)
student <- read.csv("./student/student-por.csv", header = TRUE, sep = ";")
head(student, 2)
student <- student[, !(names(student) %in% c("G1", "G2"))]
head(student, 2)
table(student$G3)
student[sapply(student, is.character)] <- lapply(student[sapply(student, is.character)], as.factor)
head(student,2)
student$pass <- ifelse(student$G3 >= 10, 1, 0)
student$pass <- as.factor(student$pass)
set.seed(321)
train_idx <- sample(1:nrow(student), 0.7*nrow(student))
train <- student[train_idx, ]
test <- student[-train_idx, ]
# start from full
full_log <- glm(pass ~ . - G3, data = train, family = "binomial")
summary(full_log)
null_log <- glm(pass ~ 1, data = train, family = "binomial")
step_log <- step(null_log,
scope = list(lower = null_log, upper = full_log),
direction = "both",
trace = FALSE) #- It's too long to show
summary(step_log)
library(boot)
cv_error <- cv.glm(train, step_log, K = 5)
cv_error$delta
cv_error10 <- cv.glm(train, step_log, K = 10)
cv_error10$delta
log_prob <- predict(step_log, test, type = "response")
log_pred <- ifelse(log_prob > 0.5, 1, 0)
log_pred <- as.factor(log_pred)
mean(log_pred != test$pass)   # error rate
mean(log_pred == test$pass)   # classification rate
table(test$pass, log_pred)
table(Actual = test$pass, Predicted = log_pred)
student$pass <- ifelse(student$G3 >= 12, 1, 0)
student$pass <- as.factor(student$pass)
table(student$pass)
set.seed(321)
train_idx <- sample(1:nrow(student), 0.7 * nrow(student))
train <- student[train_idx, ]
test <- student[-train_idx, ]
# Full logistic regression model
full_log <- glm(pass ~ . - G3, data = train, family = "binomial")
summary(full_log)
# Stepwise logistic regression
null_log <- glm(pass ~ 1, data = train, family = "binomial")
step_log <- step(null_log,
scope = list(lower = null_log, upper = full_log),
direction = "both",
trace = FALSE)
summary(step_log)
# Stepwise logistic regression
null_log <- glm(pass ~ 1, data = train, family = "binomial")
step_log <- step(null_log,
scope = list(lower = null_log, upper = full_log),
direction = "both",
trace = FALSE)
summary(step_log)
library(boot)
cv_error <- cv.glm(train, step_log, K = 5)
cv_error$delta
cv_error10 <- cv.glm(train, step_log, K = 10)
cv_error10$delta
log_prob <- predict(step_log, test, type = "response")
summary(log_prob)
log_pred <- ifelse(log_prob > 0.5, 1, 0)
actual <- factor(test$pass, levels = c(0, 1))
pred <- factor(log_pred, levels = c(0, 1))
mean(pred != actual)   # error rate
mean(pred == actual)   # classification rate
table(Actual = actual, Predicted = pred)
log_prob <- predict(step_log, test, type = "response")
summary(log_prob)
log_pred <- ifelse(log_prob > 0.5, 1, 0)
actual <- factor(test$pass, levels = c(0, 1))
pred <- factor(log_pred, levels = c(0, 1))
mean(pred != actual)   # error rate
mean(pred == actual)   # classification
table(Actual = actual, Predicted = pred)
mean(ifelse(log_prob > 0.3, 1, 0) != as.numeric(as.character(test$pass)))
mean(ifelse(log_prob > 0.7, 1, 0) != as.numeric(as.character(test$pass)))
